<!DOCTYPE html>
<html class="no-js" lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>

    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" href="/img/icon.png" />

    <link rel="stylesheet" href="/css/main.css" />

    <meta name="theme-color" content="#232328" />
    {% if description %}
      <meta name="description" content="{{ description }}" />
    {% endif %}
    {% if keywords %}
      <meta name="keywords" content="{{ keywords }}" />
    {% endif %}
    {% if author %}
      <meta name="author" content="{{ author }}" />
    {% endif %}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#content-slot" class="skip-link">Zum Inhalt springen</a>

    <header></header>

    <nav aria-label="Hauptnavigation">
      <div class="nav-top">
        <a href="/">
          <img
            src="/img/trans-shg-logo.png"
            id="trans-shg-logo"
            alt="Trans* SHG Linz Logo"
          />
        </a>
        <button
          class="hamburger"
          id="hamburger-btn"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="main-menu"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
      {% set navPages = collections.all | eleventyNavigation %}
      <ul id="main-menu">
        {%- for entry in navPages %}
          {% if entry.url == page.url %}
            <li class="is-active">
              <a href="{{ entry.url }}" aria-current="page"
                >{{ entry.title }}</a
              >
            </li>
          {% else %}
            <li>
              <a href="{{ entry.url }}">{{ entry.title }}</a>
            </li>
          {% endif %}
        {%- endfor %}
      </ul>
    </nav>

    <main>
      <div id="page-content">
        <section id="interactive-elements">
          <form>
            <fieldset>
              <legend>Einstellungen</legend>
              <label for="accessiblity-toggle">
                <input type="checkbox" id="accessiblity-toggle" />
                Gendersternchen deaktivieren
              </label>
            </fieldset>
          </form>
        </section>
        <section id="content-slot">{{ content | safe }}</section>
      </div>
    </main>

    <footer>
      <p>&copy; Lena</p>
      <p>
        Trans<span class="inclusion-star">*</span> SHG Linz / Oberösterreich
        Mitglied des Dachverbands Selbsthilfe OÖ
      </p>
    </footer>

    <script src="/js/vendor/modernizr-3.11.2.min.js"></script>
    <script src="/js/plugins.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
