<!DOCTYPE html>
<html class="no-js" lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>

    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" href="/img/icon.png" />

    <link rel="stylesheet" href="/css/main.css" />

    <meta name="theme-color" content="#232328" />
    {% if description %}
      <meta name="description" content="{{ description }}" />
    {% endif %}
    {% if keywords %}
      <meta name="keywords" content="{{ keywords }}" />
    {% endif %}
    {% if author %}
      <meta name="author" content="{{ author }}" />
    {% endif %}

    <!-- Preload critical font (latin subset covers German text) -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/montserrat-latin-wght-normal.woff2"
      crossorigin
    />

    <!-- Preload hero background image per breakpoint for LCP discovery -->
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href="/img/pexels-katie-rainbow-640.avif"
      media="(max-width: 639px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href="/img/pexels-katie-rainbow-768.avif"
      media="(min-width: 640px) and (max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href="/img/pexels-katie-rainbow-1024.avif"
      media="(min-width: 768px) and (max-width: 1023px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href="/img/pexels-katie-rainbow-1280.avif"
      media="(min-width: 1024px) and (max-width: 1279px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/avif"
      href="/img/pexels-katie-rainbow-1536.avif"
      media="(min-width: 1280px)"
      fetchpriority="high"
    />
  </head>
  <body>
    <a href="#content-slot" class="skip-link">Zum Inhalt springen</a>

    <header></header>

    <nav aria-label="Hauptnavigation">
      <div class="nav-top">
        <a href="/">
          <picture>
            <source srcset="/img/trans-shg-logo.avif" type="image/avif" />
            <img
              src="/img/trans-shg-logo.avif"
              id="trans-shg-logo"
              alt="Trans SHG Linz Logo"
              width="640"
              height="320"
              fetchpriority="high"
            />
          </picture>
        </a>
        <button
          class="hamburger"
          id="hamburger-btn"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="main-menu"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
      {% set navPages = collections.all | eleventyNavigation %}
      <ul id="main-menu">
        {%- for entry in navPages %}
          {% if entry.url == page.url %}
            <li class="is-active">
              <a href="{{ entry.url }}" aria-current="page"
                >{{ entry.title }}</a
              >
            </li>
          {% else %}
            <li>
              <a href="{{ entry.url }}">{{ entry.title }}</a>
            </li>
          {% endif %}
        {%- endfor %}
      </ul>
    </nav>

    <main>
      <div id="page-content">
        <section id="interactive-elements">
          <form>
            <fieldset>
              <legend>Einstellungen</legend>
              <label for="accessiblity-toggle">
                <input type="checkbox" id="accessiblity-toggle" />
                Gendersternchen deaktivieren
              </label>
            </fieldset>
          </form>
        </section>
        <section id="content-slot">{{ content | safe }}</section>
      </div>
    </main>

    <footer>
      <p>&copy; Lena</p>
      <p>
        Trans SHG Linz / Oberösterreich Mitglied des Dachverbands Selbsthilfe OÖ
      </p>
    </footer>

    <script src="/js/vendor/modernizr-3.11.2.min.js"></script>
    <script src="/js/plugins.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
