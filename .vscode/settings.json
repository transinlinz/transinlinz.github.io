{
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "chat.tools.terminal.autoApprove": {
    // ── File & Directory Inspection ──
    "ls": true,
    "eza": true,
    "exa": true,
    "tree": true,
    "stat": true,
    "file": true,
    "bat": true,
    "cat": true,
    "head": true,
    "tail": true,
    "less": true,
    "more": true,
    "wc": true,
    "du": true,
    "dust": true,
    "df": true,
    "duf": true,
    "realpath": true,
    "basename": true,
    "dirname": true,
    "readlink": true,

    // ── Search & Pattern Matching ──
    "rg": true,
    "grep": true,
    "egrep": true,
    "fgrep": true,
    "fd": true,
    "find": true,
    "locate": true,
    "which": true,
    "whereis": true,
    "type": true,
    "command -v": true,
    "ag": true,
    "sg --pattern": true,

    // ── Text Processing (stdout only, no file mutation) ──
    "awk": true,
    "sed -n": true,
    "sort": true,
    "uniq": true,
    "cut": true,
    "paste": true,
    "tr": true,
    "column": true,
    "fmt": true,
    "fold": true,
    "rev": true,
    "tac": true,
    "nl": true,
    "comm": true,
    "diff": true,
    "difft": true,
    "delta": true,
    "colordiff": true,
    "xxd": true,
    "od": true,
    "hexdump": true,
    "/^(md5|sha1|sha256|sha512|b2)sum\\b/": true,

    // ── JSON / YAML / Data Processing ──
    "jq": true,
    "yq": true,
    "xq": true,

    // ── Git (read-only operations only) ──
    "/^git\\s+(status|log|diff|show|branch|tag|remote|rev-parse|ls-files|blame|shortlog|describe|stash\\s+list|reflog|--no-pager)\\b/": true,
    "/^git\\s+config\\s+--get\\b/": true,

    // ── System / Environment Info ──
    "env": true,
    "printenv": true,
    "echo": true,
    "printf": true,
    "uname": true,
    "hostname": true,
    "whoami": true,
    "id": true,
    "date": true,
    "uptime": true,
    "free": true,
    "lscpu": true,
    "nproc": true,
    "arch": true,
    "locale": true,
    "getconf": true,

    // ── Process Inspection ──
    "ps": true,
    "procs": true,
    "top -bn1": true,
    "pgrep": true,
    "lsof": true,
    "ss": true,
    "netstat": true,

    // ── Node / Package Manager (read-only + project lint/test scripts) ──
    "/^node\\s+(-e|-p|--version)/": true,
    "/^pnpm\\s+(list|why|exec\\s+which)\\b/": true,
    "/^pnpm\\s+run\\s+(prettier|lint|eslint|stylelint|typecheck|test)/": true,
    "/^npm\\s+(ls|explain|view)\\b/": true,
    "/^npx\\s+--yes\\s+(tokei|scc)\\b/": true,

    // ── Misc Utility ──
    "test": true,
    "true": true,
    "false": true,
    "seq": true,
    "time": true,
    "hyperfine": true,
    "tokei": true,
    "scc": true,
    "xargs": true,

    // ── Explicit Deny (destructive / write / network commands) ──
    "rm": false,
    "rmdir": false,
    "del": false,
    "mv": false,
    "cp": false,
    "ln": false,
    "dd": false,
    "kill": false,
    "killall": false,
    "pkill": false,
    "curl": false,
    "wget": false,
    "eval": false,
    "chmod": false,
    "chown": false,
    "chgrp": false,
    "sudo": false,
    "mkfs": false,
    "mount": false,
    "umount": false,
    "reboot": false,
    "shutdown": false,
    "systemctl": false,
    "ssh": false,
    "scp": false,
    "rsync": false,
    "docker": false,
    "podman": false,
    "/^git\\s+(push|commit|reset|checkout|clean|rebase|merge|cherry-pick)\\b/": false,
    "/^(pnpm|npm|pip3?)\\s+install\\b/": false,
    "/^Remove-Item\\b/i": false
  },
  "chat.tools.terminal.blockDetectedFileWrites": true
}
