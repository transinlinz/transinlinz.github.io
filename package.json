{
  "name": "transinlinz.github.io",
  "version": "2.0.0",
  "description": "Homepage of the Trans self-help group Linz.",
  "type": "module",
  "main": "index.html",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "eleventy --serve",
    "build": "eleventy",
    "prettier": "prettier --write",
    "format": "pnpm run prettier *.md *.json *.mjs pnpm-workspace.yaml src/ .vscode/ .github/",
    "cleanup": "pnpx rimraf node_modules/ _site/",
    "reinstall": "pnpx rimraf pnpm-lock.yaml node_modules/ && pnpm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transinlinz/transinlinz.github.io.git"
  },
  "keywords": [
    "trans",
    "inter",
    "homepage",
    "self-help",
    "lgbtqi"
  ],
  "author": "Lena M.",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/transinlinz/transinlinz.github.io/issues"
  },
  "homepage": "https://github.com/transinlinz/transinlinz.github.io#readme",
  "engines": {
    "node": "^24.14.1",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "@tailwindcss/postcss": "4.2.2",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-jinja-template": "2.1.0",
    "sass": "1.99.0",
    "tailwindcss": "4.2.2"
  }
}
