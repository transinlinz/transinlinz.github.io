{
  "name": "transinlinz.github.io",
  "version": "2.0.0",
  "description": "Homepage of the Trans self-help group Linz.",
  "type": "module",
  "main": "index.html",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "eleventy --serve",
    "build": "eleventy",
    "prettier": "prettier --write",
    "format": "pnpm run prettier *.md *.json *.mjs pnpm-workspace.yaml src/ .vscode/ .github/",
    "cleanup": "pnpx rimraf node_modules/ _site/",
    "reinstall": "pnpx rimraf pnpm-lock.yaml node_modules/ && pnpm install",
    "update:all": "pnpm update --latest --interactive"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transinlinz/transinlinz.github.io.git"
  },
  "keywords": [
    "trans",
    "inter",
    "homepage",
    "self-help",
    "lgbtqi"
  ],
  "author": "Lena M.",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/transinlinz/transinlinz.github.io/issues"
  },
  "homepage": "https://github.com/transinlinz/transinlinz.github.io#readme",
  "engines": {
    "node": "^26.5.0",
    "pnpm": "11.11.0"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-navigation": "1.0.5",
    "@fontsource-variable/montserrat": "5.2.8",
    "@tailwindcss/postcss": "4.3.2",
    "autoprefixer": "10.5.2",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "prettier-plugin-jinja-template": "2.2.0",
    "sass": "1.101.0",
    "tailwindcss": "4.3.2"
  }
}
